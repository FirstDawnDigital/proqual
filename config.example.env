# ============================================================
# Ejendomsystem Konfiguration
# Kopiér denne fil til config.env og udfyld med dine værdier
# ============================================================

# --- Gmail IMAP ---
# Opret App Password under: Google-konto → Sikkerhed → App-adgangskoder
# (Kræver 2-faktor-godkendelse aktiveret)
GMAIL_ADDRESS=slejlighed@gmail.com
GMAIL_APP_PASSWORD=hdegyaxxvsurubbf

# --- Google Sheets ---
# ID'et findes i URL'en: docs.google.com/spreadsheets/d/DETTE_ER_ID/edit
SHEETS_RENTAL_AGGREGATES_ID=din-google-sheets-id-her
SHEETS_RENTABILITY_ID=din-rentabilitetsberegner-sheets-id-her

# --- Database ---
DB_PATH=data/ejendom.db

# --- Scraping (lejeboliger) ---
# Kør lejeboligs-scraper (true/false) - email-parser er nemmere og mere stabil
ENABLE_SCRAPING=false
SCRAPING_DELAY_SECONDS=3

# --- Boligsiden (boliger til salg) ---
# Søge-URL fra Boligsiden - indsæt din søge-URL her
# Eksempel: https://www.boligsiden.dk/tilsalg/villa,ejerlejlighed,raekkehus?priceMax=2500000&polygon=...
BOLIGSIDEN_SEARCH_URL=
# Maks antal sider at scrape (20 sider ≈ 400 boliger)
BOLIGSIDEN_MAX_PAGES=20
# Forsinkelse i sekunder mellem requests (respekter serveren)
BOLIGSIDEN_DELAY_SECONDS=3.0

# --- Email parsing ---
# Hvilke afsendere skal vi kigge efter?
BOLIGPORTAL_SENDER=noreply@boligportal.dk
LEJEBOLIG_SENDER=agent@lejebolig.dk
BOLIGSIDEN_SENDER=agent@boligsiden.dk

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=data/ejendom.log
